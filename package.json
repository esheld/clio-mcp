  "description": "MCP server for the Clio legal practice management API — access matters, tasks, activities, and communications",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "clio-mcp-server": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
